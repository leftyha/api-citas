# Entorno
BOOKING_ENV=dev
BOOKING_STRICT_DEPLOY=false

# Base de datos (SQL Server)
BOOKING_DB_DRIVER=sqlsrv
BOOKING_DB_HOST=127.0.0.1
BOOKING_DB_PORT=1433
BOOKING_DB_NAME=booking_db
BOOKING_DB_USER=booking_user
BOOKING_DB_PASSWORD=replace-with-strong-db-password
BOOKING_DB_ENCRYPT=true
BOOKING_DB_TRUST_SERVER_CERTIFICATE=false

# App
BOOKING_TIMEZONE=UTC
BOOKING_BASE_PATH=
BOOKING_CORS_ALLOWED_ORIGINS=*

# Seguridad (OBLIGATORIO definir valores fuertes en producción)
BOOKING_TOKEN_SECRET=replace-with-strong-random-secret
BOOKING_TOKEN_KEY_ID=booking-token-2026-01
BOOKING_TOKEN_PREFIX=apt_
BOOKING_ADMIN_TOKEN=replace-with-strong-admin-token

# Reglas de negocio
BOOKING_DEFAULT_DURATION_MINUTES=30
BOOKING_TOKEN_TTL_SECONDS=7776000

# Rate limit
BOOKING_RATE_LIMIT_BACKEND=database
BOOKING_RATE_LIMIT_MAX_ATTEMPTS=60
BOOKING_RATE_LIMIT_WINDOW_SECONDS=60

# Red/observabilidad
BOOKING_TRUSTED_PROXIES=
BOOKING_LOG_PATH=./logs/booking-api.log
