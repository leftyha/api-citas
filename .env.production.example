# =====================================
# API Citas - Plantilla para PRODUCCIÓN
# =====================================
# Copia este archivo a .env en el servidor y reemplaza los valores marcados con <<...>>.

# Entorno
BOOKING_ENV=production
BOOKING_STRICT_DEPLOY=true

# Base de datos (SQL Server)
BOOKING_DB_DRIVER=sqlsrv
BOOKING_DB_HOST=<<DB_HOST>>
BOOKING_DB_PORT=1433
BOOKING_DB_NAME=<<DB_NAME>>
BOOKING_DB_USER=<<DB_USER>>
BOOKING_DB_PASSWORD=<<DB_PASSWORD>>
BOOKING_DB_ENCRYPT=true
BOOKING_DB_TRUST_SERVER_CERTIFICATE=false

# App
BOOKING_TIMEZONE=America/Bogota
BOOKING_BASE_PATH=
BOOKING_CORS_ALLOWED_ORIGINS=<<FRONTEND_ORIGIN_1>>,<<FRONTEND_ORIGIN_2>>

# Seguridad
BOOKING_TOKEN_SECRET=<<APPOINTMENT_TOKEN_SECRET_64+_CHARS>>
BOOKING_TOKEN_KEY_ID=booking-token-2026-04
BOOKING_TOKEN_PREFIX=apt_
BOOKING_ADMIN_TOKEN=<<ADMIN_BEARER_TOKEN_40+_CHARS>>

# Reglas de negocio
BOOKING_DEFAULT_DURATION_MINUTES=30
BOOKING_TOKEN_TTL_SECONDS=7776000

# Rate limit
BOOKING_RATE_LIMIT_BACKEND=database
BOOKING_RATE_LIMIT_MAX_ATTEMPTS=60
BOOKING_RATE_LIMIT_WINDOW_SECONDS=60

# Red/observabilidad
BOOKING_TRUSTED_PROXIES=<<PROXY_IP_1>>,<<PROXY_IP_2>>
BOOKING_LOG_PATH=./logs/booking-api.log
